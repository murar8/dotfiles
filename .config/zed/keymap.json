[
  // Workspace
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-/": "workspace::NewCenterTerminal",
      "ctrl-`": null, // default terminal_panel::Toggle — avoid dock terminal
      // "ctrl-?": ["task::Spawn", { "task_name": "Claude" }], // default agent::ToggleFocus
      "ctrl-shift-g": ["task::Spawn", { "task_name": "Lazygit" }], // default git_panel::ToggleFocus
      "ctrl-s": "workspace::SaveAll", // default workspace::Save
    },
  },

  // Editor
  {
    "context": "Editor && !agent_diff",
    "bindings": {
      "ctrl-alt-y": "workspace::ToggleAllDocks", // default git::ToggleStaged; matches Workspace
    },
  },

  // Terminal
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-t": null, // default project_symbols::Toggle
    },
  },

  // Vim
  {
    // https://zed.dev/docs/vim#example-configuration
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs",
    "bindings": {
      // Traditional Vim behavior
      "q": "vim::AnyQuotes", // default vim::MiniQuotes
      "b": "vim::AnyBrackets", // default vim::Parentheses
      // mini.ai plugin behavior
      "Q": "vim::MiniQuotes",
      "B": "vim::MiniBrackets",
    },
  },
  // In VimScript, this would look like this:
  // set whichwrap+=<,>,[,],h,l
  {
    "context": "VimControl && !menu",
    "bindings": {
      "left": "vim::WrappingLeft", // default vim::Left
      "right": "vim::WrappingRight", // default vim::Right
      "h": "vim::WrappingLeft", // default vim::Left
      "l": "vim::WrappingRight", // default vim::Right
    },
  },
]
