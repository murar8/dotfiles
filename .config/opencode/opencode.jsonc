{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.pfx": "deny",
      "*.jks": "deny",
      "*.keystore": "deny",
      "*.kdbx": "deny",
      "*.ovpn": "deny",
      "*.pp": "deny",
      "*id_rsa*": "deny",
      "*id_ecdsa*": "deny",
      "*id_ed25519*": "deny",
      "*id_dsa*": "deny",
      "*.netrc": "deny",
      "*._netrc": "deny",
      "*.npmrc": "deny",
      "*.pypirc": "deny",
      "*.pgpass": "deny",
      "*.my.cnf": "deny",
      "*.htpasswd": "deny",
      "*.git-credentials": "deny",
      "*credentials.json": "deny",
      "*credentials.yml": "deny",
      "*credentials.yaml": "deny",
      "*secrets.json": "deny",
      "*secrets.yml": "deny",
      "*secrets.yaml": "deny",
      "*secrets.toml": "deny",
      "*secret_key*": "deny",
      "*api_keys*": "deny",
      "*api-keys*": "deny",
      "*api_tokens*": "deny",
      "*access_tokens*": "deny",
      "*private_tokens*": "deny",
      "*tokens.json": "deny",
      "*tokens.csv": "deny",
      "*tokens.txt": "deny",
      "*.jwt": "deny",
      "*.vault": "deny",
      "*vault.yml": "deny",
      "*vault.env": "deny",
      "*vault.json": "deny",
      "*kubeconfig*": "deny",
      "*service-account*.json": "deny",
      "*service_account*.json": "deny",
      "*.tfvars": "deny",
      "*wp-config.php": "deny",
      "*.rdp": "deny",
      "*.docker/config.json": "deny",
      "*.dockercfg": "deny",
      "*/etc/shadow*": "deny",
      "*/etc/passwd*": "deny",
      "*/etc/ssh/sshd_config*": "deny",
      "*/etc/ssh/ssh_config*": "deny",
      "*.ssh/id_rsa*": "deny",
      "*.ssh/id_ecdsa*": "deny",
      "*.ssh/id_ed25519*": "deny",
      "*.ssh/id_dsa*": "deny",
      "*.ssh/config": "deny",
      "*.aws/credentials*": "deny",
      "*.gnupg/*": "deny",
      "*.bash_history": "deny",
      "*.zsh_history": "deny",
      "*.ssh/known_hosts": "deny"
    },
    "glob": "allow",
    "grep": "ask",
    "list": "allow",
    "edit": "ask",
    "bash": "ask",
    "task": "ask",
    "todowrite": "ask",
    "question": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "lsp": "ask",
    "skill": "ask",
    "external_directory": "ask",
    "doom_loop": "ask"
  }
}
